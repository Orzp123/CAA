# Auto detect text files and perform LF normalization
* text=auto

# Java
*.java text
*.properties text
*.xml text
*.yml text
*.yaml text

# Frontend
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.css text
*.html text
*.md text

# Shell scripts
*.sh text eol=lf

# Docker
Dockerfile text
docker-compose*.yml text

# SQL
*.sql text

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
