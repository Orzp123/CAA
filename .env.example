# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=caa
MYSQL_USER=caa
MYSQL_PASSWORD=caa_secret
MYSQL_PORT=3306

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_PORT=9092

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_ENDPOINT=http://localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Apache Doris ──────────────────────────────────────────────────────────────
DORIS_FE_HOST=localhost
DORIS_FE_PORT=9030
DORIS_FE_HTTP_PORT=8030
DORIS_ROOT_PASSWORD=doris_secret

# ── Apache Flink ──────────────────────────────────────────────────────────────
FLINK_UI_PORT=8081

# ── Temporal ──────────────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_UI_PORT=8088

# ── Nacos ─────────────────────────────────────────────────────────────────────
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
# Must be a Base64-encoded string ≥ 32 chars for Nacos auth token
NACOS_AUTH_TOKEN=SecretKey012345678901234567890123456789012345678901234567890123456789

# ── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

# ── Spring Boot ───────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
BACKEND_PORT=8080

# ── Next.js ───────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_URL=http://backend:8080/api
